[TITLE]
Small valid EPANET 2.2 network for parser tests. Units: LPS, H-W.

[JUNCTIONS]
;ID      Elevation   Demand   Pattern
 J1      100          5        P1     ;
 J2       95         10               ;
 J3       90          0               ;

[RESERVOIRS]
;ID      Head    Pattern
 R1      120             ;

[TANKS]
;ID      Elevation  InitLevel  MinLevel  MaxLevel  Diameter  MinVol
 T1      110         5          0         12        20        0   ;

[PIPES]
;ID      Node1   Node2   Length  Diameter  Roughness  MinorLoss  Status
 P1      R1      J1      500     300       130        0          Open ;
 P2      J1      J2      400     250       130        0          Open ;
 P3      J2      J3      300     200       130        0          Open ;
 P4      J1      T1      150     200       130        0          Open ;

[PUMPS]
;ID      Node1   Node2   Properties
 PU1     R1      J1      HEAD C1 SPEED 1.0 ;

[VALVES]
;ID      Node1   Node2   Diameter  Type  Setting  MinorLoss
 V1      J2      J3      200       TCV   0        0 ;

[CURVES]
;ID      X        Y
 C1      0        60 ;
 C1      50       45 ;
 C1      100      20 ;

[PATTERNS]
;ID      Multipliers
 P1      1.0  1.2  0.8  1.0 ;

[COORDINATES]
;Node    X       Y
 J1      1.0     0.0
 J2      2.0     0.0
 J3      3.0     0.0
 R1      0.0     0.0
 T1      1.0     1.0

[OPTIONS]
UNITS      LPS
HEADLOSS   H-W

[END]
