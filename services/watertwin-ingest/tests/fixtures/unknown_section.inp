[TITLE]
Network with an unknown [WIDGETS] section. Unknown sections become warnings and
are never silently dropped, and never crash the parser.

[JUNCTIONS]
;ID      Elevation   Demand
 J1      100          5   ;
 J2       95         10   ;

[WIDGETS]
;ID      SomeValue
 W1      42   ;
 W2      99   ;

[PIPES]
;ID      Node1   Node2   Length  Diameter  Roughness  Status
 P1      J1      J2      400     250       130        Open ;

[OPTIONS]
UNITS      CMH
HEADLOSS   H-W

[END]
