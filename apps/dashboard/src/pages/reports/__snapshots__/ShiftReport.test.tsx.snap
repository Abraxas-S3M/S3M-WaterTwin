// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ShiftReport print view > matches the paginated shift-report snapshot 1`] = `
<div
  class="report-view"
  data-testid="shift-report"
>
  <div
    aria-label="Report actions"
    class="report-toolbar"
    role="toolbar"
  >
    <div
      class="report-toolbar-title"
    >
      Shift Report
    </div>
    <div
      class="report-toolbar-actions"
    >
      <button
        class="btn primary"
        data-testid="report-print"
      >
        Print / Save as PDF
      </button>
      <button
        class="btn ghost"
        data-testid="report-close"
      >
        Close
      </button>
    </div>
  </div>
  <div
    class="report-sheet"
  >
    <section
      class="report-page"
    >
      <header
        class="report-header"
      >
        <div>
          <h1
            class="report-title"
          >
            Shift Report
          </h1>
          <div
