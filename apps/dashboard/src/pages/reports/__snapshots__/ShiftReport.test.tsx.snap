            <td
              class="num"
            >
              34
            </td>
            <td>
              elevated
               risk
            </td>
          </tr>
        </tbody>
      </table>
      <h2
        class="report-h2"
      >
        Active alarms (
        1
        )
      </h2>
      <table
        class="report-table"
        data-testid="shift-alarms"
      >
        <thead>
          <tr>
            <th>
              Severity
            </th>
            <th>
              Asset
            </th>
            <th>
              Message
            </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>
              high
            </td>
            <td>
              High-Pressure Pump A
            </td>
            <td>
              High-Pressure Pump A: health 63.2 (Degraded), anomaly 0.61
            </td>
          </tr>
        </tbody>
      </table>
    </section>
    <section
      class="report-page"
    >
      <h2
        class="report-h2"
      >
