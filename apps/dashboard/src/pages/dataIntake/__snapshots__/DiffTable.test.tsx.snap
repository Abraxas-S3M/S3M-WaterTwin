                data-testid="provenance-badge"
                title="Directly measured instrument data."
              >
                Measured
              </span>
            </td>
            <td>
              <div
                class="stack"
              >
                <label>
                  <input
                    data-testid="ingest-accept-r2"
                    type="checkbox"
                  />
                   
                  Accept
