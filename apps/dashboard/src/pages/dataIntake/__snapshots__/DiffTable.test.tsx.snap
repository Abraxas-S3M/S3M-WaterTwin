// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`DiffTable > matches the grouped diff snapshot 1`] = `
<div>
  <div
    class="stack"
    data-testid="ingest-diff-table"
  >
    <div
      class="card"
      data-testid="ingest-diff-group-asset-hierarchy"
    >
      <div
        class="page-header"
      >
        <h3>
          Asset Hierarchy
        </h3>
        <button
