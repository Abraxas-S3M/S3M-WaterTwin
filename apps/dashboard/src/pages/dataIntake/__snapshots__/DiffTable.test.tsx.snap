          data-testid="ingest-bulk-accept-asset-hierarchy"
          type="button"
        >
          Accept all in this group
        </button>
      </div>
      <table
        class="data"
      >
        <thead>
          <tr>
            <th>
              Field
            </th>
            <th>
              Current value
            </th>
            <th>
              Proposed value
            </th>
            <th>
              Source
            </th>
            <th>
              Provenance
            </th>
            <th>
              Decision
            </th>
          </tr>
        </thead>
        <tbody>
          <tr
            data-testid="ingest-diff-row-r1"
          >
            <td>
              <div>
                name
              </div>
              <div
                class="muted"
              >
                AST-HPP-01
              </div>
              <span
                class="status-chip rejected"
                data-testid="ingest-safety-flag-r1"
                title="Asset hierarchy, rated equipment and alarm thresholds require a separate approver (separation of duties)."
              >
                Safety-relevant
              </span>
            </td>
            <td
              class="muted"
            >
              Pump A
            </td>
            <td>
              <strong>
                High-Pressure Pump A
              </strong>
            </td>
            <td
              class="muted"
            >
              <code>
                [JUNCTIONS] line 12
              </code>
            </td>
            <td>
              <span
                class="prov-badge unvalidated"
                data-provenance="preliminary"
                data-testid="provenance-badge"
                title="Preliminary model output — pending calibration/validation."
              >
                Preliminary
              </span>
            </td>
            <td>
              <div
                class="stack"
              >
                <label>
                  <input
                    data-testid="ingest-accept-r1"
                    type="checkbox"
                  />
                   
                  Accept
                </label>
                <button
                  class="btn"
                  data-testid="ingest-reject-r1"
                  type="button"
                >
                  Reject
                </button>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    <div
      class="card"
      data-testid="ingest-diff-group-tag-mapping"
    >
      <div
        class="page-header"
      >
        <h3>
          Tag Mapping
        </h3>
        <button
          class="btn"
          data-testid="ingest-bulk-accept-tag-mapping"
          type="button"
        >
          Accept all in this group
        </button>
      </div>
      <table
        class="data"
      >
        <thead>
          <tr>
            <th>
              Field
            </th>
            <th>
              Current value
            </th>
            <th>
              Proposed value
            </th>
            <th>
              Source
            </th>
            <th>
              Provenance
            </th>
            <th>
              Decision
            </th>
          </tr>
        </thead>
        <tbody>
          <tr
            data-testid="ingest-diff-row-r2"
          >
            <td>
