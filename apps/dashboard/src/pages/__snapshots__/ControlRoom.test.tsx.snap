// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ControlRoom display mode > matches the large-format KPI snapshot (production slide) 1`] = `
<div
  class="control-room"
  data-testid="control-room"
>
  <header
    class="cr-header"
  >
    <div
      class="cr-brand"
    >
      <span
        class="cr-title"
      >
        S3M-WaterTwin
      </span>
      <span
        class="cr-sub"
      >
        Control Room
      </span>
    </div>
