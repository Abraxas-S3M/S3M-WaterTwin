# Copy to .env and adjust as needed: cp .env.example .env

# Seconds between synthetic-plant telemetry ticks.
WATERTWIN_TICK_SECONDS=5

# Base URL of S3M-Core. Leave blank to always use the local fallback recommender.
# In docker compose this defaults to the docker host (host.docker.internal).
WATERTWIN_S3M_BASE_URL=http://host.docker.internal:8081

# Timeout (seconds) for calls to S3M-Core before falling back locally.
WATERTWIN_S3M_TIMEOUT=2.0

# Deterministic seed for the synthetic plant.
WATERTWIN_SEED=42

# Log level (DEBUG, INFO, WARNING, ERROR).
WATERTWIN_LOG_LEVEL=INFO

# --- Advisory service-event bus (NATS) ---
# Service events (telemetry-ingested, alert-raised, workorder-created,
# config-published, audit-appended) are published to NATS so other services can
# react. The bus is ADVISORY / NOTIFICATION ONLY -- it never carries a control
# command (the publisher guards every subject). If NATS_URL is unset or the
# broker is unreachable, the API degrades gracefully: it logs, counts a metric,
# and falls back to direct in-process delivery. State is surfaced at
# GET /api/v1/events/status and in /health (event_bus.*).
NATS_URL=nats://nats:4222
# Connect timeout (seconds) before the bus degrades to direct delivery.
NATS_CONNECT_TIMEOUT=2.0

# --- Identity / RBAC (Commercial Hardening #1) ---
# Authentication is ENFORCED by default. Set to true ONLY for local dev/tests to
# bypass auth with a synthetic admin principal. See docs/security/identity.md.
WATERTWIN_AUTH_DISABLED=false
# Expected token issuer (browser-facing Keycloak URL). JWKS defaults to
# <issuer>/protocol/openid-connect/certs unless WATERTWIN_OIDC_JWKS_URI is set.
WATERTWIN_OIDC_ISSUER=http://localhost:8180/realms/watertwin
WATERTWIN_OIDC_JWKS_URI=http://keycloak:8080/realms/watertwin/protocol/openid-connect/certs
# Optional expected audience (aud). Audience verification is skipped when unset.
# WATERTWIN_OIDC_AUDIENCE=watertwin-api

# --- Deployment profile (edge / XiiD-ready one-way posture) ---
# standard      -- platform MAY pull telemetry from a real OT feed (read-only).
# one_way_diode -- SealedTunnel / data-diode topology: the edge gateway PUSHES
#                  telemetry and the platform NEVER initiates a connection toward
#                  OT. Any platform->OT request path (opcua/modbus/historian
#                  rest|sql) is DISABLED at startup (fail-closed); only synthetic
#                  and gateway-pushed / historian:csv feeds are allowed. An
#                  unknown value fails closed to one_way_diode.
# See docs/deployment/edge-xiid-reference.md.
DEPLOYMENT_PROFILE=standard
# --- Telemetry ingest (edge store-and-forward) ---
# Provisioned shared token the edge-gateway presents (X-Ingest-Token header) to
# POST /api/v1/ingestion/telemetry. Set this to a strong random value in real
# deployments; the edge-gateway must be given the SAME value. When empty, the
# ingest path falls back to role-based auth, so under enforced auth the gateway
# needs this set to forward telemetry. Placeholder only — replace before use.
WATERTWIN_INGEST_TOKEN=replace-with-a-strong-random-ingest-token

# --- Read-only OT connectors (Commercial Hardening #2) ---
# Telemetry is a pluggable, strictly READ-ONLY source. Default is the built-in
# synthetic plant. A real OT feed can be selected; if it is configured but
# unreachable the service logs and FALLS BACK to synthetic (never crashes) and
# reports the active source + fallback in /health. No source ever writes to a
# control system.
#   synthetic | opcua | modbus | historian
OT_SOURCE=synthetic
# Tag map (name under data/tag-maps/, or a path) used to normalize a real OT
# feed onto the canonical model. Required for opcua/modbus/historian.
# OT_TAG_MAP=example-plant

# OPC UA (asyncua CLIENT only, read-only). NodeIds are comma-separated; each
# NodeId is the customer tag looked up in the tag map.
# OT_OPCUA_ENDPOINT=opc.tcp://plc-host:4840
# OT_OPCUA_NODE_IDS=ns=2;s=HPP_A.WindingTemp,ns=2;s=HPP_A.Vibration

# Modbus (pymodbus, READ function codes only). Registers are comma-separated
# "<kind>:<address>[:<count>]" with kind = coil|discrete|holding|input.
# OT_MODBUS_HOST=plc-host
# OT_MODBUS_PORT=502
# OT_MODBUS_UNIT=1
# OT_MODBUS_REGISTERS=holding:0,holding:1,input:0

# Historian (read-only REST / SQL / CSV pull). Access = csv|rest|sql.
# OT_HISTORIAN_KIND=csv
# OT_HISTORIAN_CSV_PATH=/data/historian-export.csv
# OT_HISTORIAN_URL=http://historian-host/api/readings
# OT_HISTORIAN_DSN=postgresql://reader:reader@historian-db:5432/historian
# OT_HISTORIAN_QUERY=SELECT tag, value, timestamp FROM latest_readings

# --- Licensing / entitlements (Administration) ---
# Feature-gating by tenant/plan. This is a product-packaging concern ONLY and
# never affects the advisory/read-only safety boundary. Unset => "enterprise"
# (all features, unlimited), so a default deployment gates nothing.
# Named plan: enterprise | professional | standard | starter
WATERTWIN_PLAN=enterprise
# Tenant identifier recorded in usage metering / billing export.
WATERTWIN_TENANT_ID=default
# Optional JSON override of the plan, e.g.
# WATERTWIN_LICENSE={"plan":"custom","features":["water_quality"],"limits":{"max_assets":10}}

# --- Signed-update channel (Administration) ---
# The service VERIFIES a signed release manifest but NEVER auto-applies it.
WATERTWIN_UPDATE_CHANNEL=stable
# Release public key used to verify update manifests (Ed25519). Provide a PEM
# or a raw 32-byte hex key. Leave unset to disable verification.
# WATERTWIN_UPDATE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# WATERTWIN_UPDATE_PUBLIC_KEY_HEX=

# Directory of CycloneDX SBOMs bundled into support archives.
# WATERTWIN_SBOM_DIR=docs/licensing/sbom
# --- CMMS (maintenance system of record) integration ---
# Work orders are derived from predictive-maintenance alerts (traceable to the
# originating model + evidence) and shown in the Maintenance Center. The CMMS
# adapter is STRICTLY READ-ONLY by default (pull work orders + asset history).
# Set CMMS_WRITE_BACK_ENABLED=true to allow creating a CMMS *ticket* for an
# operator-APPROVED work order. IMPORTANT: a CMMS write-back is a business-system
# ticket, NEVER an OT/control path, and only ever happens after operator
# approval. It never commands a device and never enables control writes.
CMMS_WRITE_BACK_ENABLED=false
# Human-readable name of the CMMS system of record.
CMMS_SYSTEM=synthetic-cmms
# --- Edge gateway (outbound-only, read-only OT edge collector) ---
# The edge-gateway reuses the same OT_SOURCE / OT_* read-only source config
# above. It reads the OT feed, validates data quality, buffers to a local
# ENCRYPTED store-and-forward queue, and PUSHES canonical telemetry OUTBOUND to
# the watertwin-api ingest endpoint. It binds no inbound listener.
# EDGE_GATEWAY_ID=edge-gw-01
# Outbound push target (watertwin-api). In docker compose defaults to the API
# service on the internal network.
EDGE_GATEWAY_API_URL=http://watertwin-api:8000
# EDGE_GATEWAY_API_TOKEN=<service-bearer-token>
# Stable passphrase for the at-rest buffer encryption key. MUST be set and kept
# stable for the store-and-forward buffer to survive restarts encrypted.
# EDGE_GATEWAY_BUFFER_KEY=change-me-to-a-long-random-passphrase
# EDGE_GATEWAY_POLL_INTERVAL_S=5
# Data-quality thresholds.
# EDGE_GATEWAY_STALENESS_LIMIT_S=60
# EDGE_GATEWAY_FROZEN_LIMIT=10
# EDGE_GATEWAY_DEADBAND=0.0

# Dashboard OIDC login (baked into the SPA build as Vite env).
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=watertwin
VITE_KEYCLOAK_CLIENT_ID=watertwin-dashboard
